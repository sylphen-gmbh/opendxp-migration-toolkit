#!/bin/sh
#
# Guard pushes to the public GitHub remote.
#
# Only `main`, `public/*` branches and tags may be pushed to GitHub. Everything
# else (internal/*, wip/*, feature/*, …) stays on the internal GitLab remote.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Args: $1 = remote name, $2 = remote URL
# Stdin lines: <local ref> <local sha> <remote ref> <remote sha>

remote_name="$1"
remote_url="$2"

# Only guard the GitHub remote; pushes to GitLab (origin) are unrestricted.
case "$remote_name $remote_url" in
  *github* | *github.com*) ;;
  *) exit 0 ;;
esac

status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_ref" ] && continue
  case "$local_ref" in
    refs/heads/main) ;;
    refs/heads/public/*) ;;
    refs/tags/*) ;;
    *)
      echo "pre-push: refusing to push '$local_ref' to GitHub." >&2
      echo "          Only 'main', 'public/*' and tags are allowed on the public remote." >&2
      status=1
      ;;
  esac
done

exit $status
